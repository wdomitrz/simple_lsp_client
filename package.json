{
  "name": "simple-lsp-client",
  "displayName": "Simple LSP Client",
  "description": "A configurable VS Code LSP client extension.",
  "version": "0.0.1",
  "private": true,
  "publisher": "wdomitrz",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/wdomitrz/simple_lsp_client#readme",
  "bugs": {
    "url": "https://github.com/wdomitrz/simple_lsp_client/issues"
  },
  "keywords": [
    "lsp",
    "language-server",
    "language-client",
    "ruff",
    "basedpyright",
    "clangd"
  ],
  "qna": false,
  "preview": true,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/wdomitrz/simple_lsp_client.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage",
    "onCommand:simpleLspClient.restartServers",
    "onCommand:simpleLspClient.showStatus"
  ],
  "contributes": {
    "commands": [
      {
        "command": "simpleLspClient.restartServers",
        "title": "Simple LSP Client: Restart Servers"
      },
      {
        "command": "simpleLspClient.showStatus",
        "title": "Simple LSP Client: Show Status"
      }
    ],
    "configuration": {
      "title": "Simple LSP Client",
      "properties": {
        "simpleLspClient.servers": {
          "type": "object",
          "default": {},
          "markdownDescription": "Named LSP servers to start. Each key is a server name.",
          "additionalProperties": {
            "type": "object",
            "required": [
              "cmd",
              "filetypes"
            ],
            "additionalProperties": false,
            "properties": {
              "cmd": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "markdownDescription": "Command and arguments used to start the LSP server over stdio."
              },
              "filetypes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "markdownDescription": "VS Code language IDs this LSP server should attach to."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "markdownDescription": "Environment variables to add or override for the server process."
              },
              "initializationOptions": {
                "type": "object",
                "markdownDescription": "JSON object passed to the server as LSP initializationOptions."
              }
            }
          },
          "examples": [
            {
              "ruff": {
                "cmd": [
                  "ruff",
                  "server"
                ],
                "filetypes": [
                  "python"
                ]
              }
            }
          ]
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --minify --outfile=dist/extension.js",
    "compile": "npm run typecheck && npm run bundle",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write package.json package-lock.json tsconfig.json eslint.config.mjs .prettierrc.json README.md STATUS.md src/**/*.ts",
    "format:check": "prettier --check package.json package-lock.json tsconfig.json eslint.config.mjs .prettierrc.json README.md STATUS.md src/**/*.ts",
    "test": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.6.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
