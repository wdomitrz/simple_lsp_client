{
  "name": "simple-lsp-client",
  "displayName": "Simple LSP Client",
  "description": "A configurable VS Code LSP client extension.",
  "version": "0.0.1",
  "private": true,
  "publisher": "local",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/wdomitrz/simple_lsp_client.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap --outfile=dist/extension.js",
    "compile": "npm run typecheck && npm run bundle",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write package.json package-lock.json tsconfig.json eslint.config.mjs .prettierrc.json src/**/*.ts",
    "format:check": "prettier --check package.json package-lock.json tsconfig.json eslint.config.mjs .prettierrc.json src/**/*.ts",
    "test": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.6.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
